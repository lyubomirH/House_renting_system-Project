@{
    ViewData["Title"] = "Page Not Found";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-gradient bg-warning text-white py-4 text-center" style="background: linear-gradient(135deg, #f0ad4e 0%, #ec971f 100%);">
                    <i class="fas fa-search fa-3x mb-2"></i>
                    <h1 class="display-4 mb-0">404</h1>
                    <h3 class="mb-0">Page Not Found</h3>
                </div>
                <div class="card-body p-5 text-center">
                    <i class="fas fa-home fa-4x text-muted mb-4"></i>
                    <h4 class="text-warning mb-3">Oops! We couldn't find that page.</h4>
                    <p class="lead text-muted mb-4">
                        The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
                    </p>

                    <div class="d-grid gap-3 d-sm-flex justify-content-center">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-4">
                            <i class="fas fa-arrow-left"></i> Back to Home
                        </a>
                        <a asp-controller="House" asp-action="AllHouses" class="btn btn-outline-success btn-lg px-4">
                            <i class="fas fa-building"></i> Browse All Houses
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15) !important;
        }
</style>