@{
    ViewData["Title"] = "Unauthorized Access";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-gradient bg-danger text-white py-4 text-center" style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);">
                    <i class="fas fa-lock fa-3x mb-2"></i>
                    <h1 class="display-4 mb-0">401</h1>
                    <h3 class="mb-0">Unauthorized Access</h3>
                </div>
                <div class="card-body p-5 text-center">
                    <i class="fas fa-user-shield fa-4x text-muted mb-4"></i>
                    <h4 class="text-danger mb-3">Access Denied!</h4>
                    <p class="lead text-muted mb-4">
                        You don't have permission to view this page.
                    </p>
                    <div class="alert alert-warning">
                        <i class="fas fa-info-circle"></i> Please log in with appropriate credentials to access this resource.
                    </div>
                    <div class="d-grid gap-3 d-sm-flex justify-content-center mt-4">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg px-4">
                            <i class="fas fa-sign-in-alt"></i> Log In
                        </a>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                            <i class="fas fa-home"></i> Back to Home
                        </a>
                    </div>
                </div>
                <div class="card-footer bg-light text-center text-muted py-3">
                    <small>Need help? <a asp-controller="Home" asp-action="Contact">Contact Support</a></small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15) !important;
        }
</style>