@{
    ViewData["Title"] = "Server Error";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-gradient bg-danger text-white py-4 text-center" style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);">
                    <i class="fas fa-server fa-3x mb-2"></i>
                    <h1 class="display-4 mb-0">500</h1>
                    <h3 class="mb-0">Internal Server Error</h3>
                </div>
                <div class="card-body p-5 text-center">
                    <i class="fas fa-cogs fa-4x text-muted mb-4"></i>
                    <h4 class="text-danger mb-3">Something went wrong!</h4>
                    <p class="lead text-muted mb-4">
                        We're experiencing technical difficulties. Our team has been notified and is working on a fix.
                    </p>
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i> Please try again in a few minutes.
                    </div>
                    
                    <!-- Action Buttons -->
                    <div class="d-grid gap-3 d-sm-flex justify-content-center mt-4">
                        <button onclick="window.location.reload();" class="btn btn-primary btn-lg px-4">
                            <i class="fas fa-sync-alt"></i> Try Again
                        </button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                            <i class="fas fa-home"></i> Back to Home
                        </a>
                    </div>
                    
                    <!-- Error Reference -->
                    <div class="mt-4 p-3 bg-light rounded">
                        <small class="text-muted">
                            <i class="far fa-clock"></i> Error Reference:
                            <span class="font-monospace">@(Guid.NewGuid().ToString().Substring(0, 8).ToUpper())</span>
                        </small>
                    </div>
                </div>
                <div class="card-footer bg-light text-center text-muted py-3">
                    <small>If the problem persists, please <a asp-controller="Home" asp-action="Contact">contact our support team</a></small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15) !important;
        }

    .font-monospace {
        font-family: monospace;
        background: #e9ecef;
        padding: 2px 6px;
        border-radius: 4px;
    }
</style>